        {"name": "Internal plaster (both sides)", "unit": "m2", "source": "Net wall area (both sides, for plaster/paint)", "waste": "plaster.internal"},
        {"name": "Internal paint (both sides)", "unit": "m2", "source": "Net wall area (both sides, for plaster/paint)", "waste": "paint.standard"}
